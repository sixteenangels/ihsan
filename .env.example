VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-publishable-key"
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"

RESEND_API_KEY="your-resend-api-key"
EMAIL_FROM_NAME="AJYN"
FROM_EMAIL="AJYN <no-reply@ajynworld.com>"
REPLY_TO_EMAIL="support@ajynworld.com"
EMAIL_PROVIDER_PREFERENCE="resend_only"

GMAIL_SMTP_HOST="smtp.gmail.com"
GMAIL_SMTP_PORT="465"
GMAIL_SMTP_USER="private-smtp-login@gmail.com"
GMAIL_SMTP_PASS="your-gmail-app-password"
GMAIL_FROM_EMAIL="AJYN <no-reply@ajynworld.com>"
# Gmail SMTP will not be used unless GMAIL_FROM_EMAIL is a verified "Send mail as"
# alias and is different from GMAIL_SMTP_USER, so the private SMTP login is hidden.
GMAIL_ALLOW_SEND_AS_ALIAS="false"
